# Song generation strategy: mock (offline) or suno (api.sunoapi.org)
GENERATOR_STRATEGY=mock

# Required when GENERATOR_STRATEGY=suno — never commit the real key
SUNO_API_KEY=

# Required for Google Sign-In backend token audience verification
GOOGLE_CLIENT_ID=
# Must exactly match Authorized redirect URI in Google OAuth client
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/user/auth/google/redirect/